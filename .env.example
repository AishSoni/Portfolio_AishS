# Password for protected pages/routes
PAGE_ACCESS_PASSWORD=password

# MERM — Resume Serving Route (spec 09)
# This deployment's tenant (RLS-scoped, every query is filtered by this)
MERM_USER_ID=

# Supabase (read-only, RLS-scoped credential — NEVER use service_role here)
SUPABASE_URL=
SUPABASE_PORTFOLIO_KEY=

# MERM API (Render backend)
MERM_API_URL=
SECRET_PORTFOLIO=

# Optional: portfolio origin registered in MERM users.baseUrl (defaults to once-ui baseURL)
# Used by /api/analytics proxy for low-trust CORS resolution on MERM.
PORTFOLIO_ORIGIN=
